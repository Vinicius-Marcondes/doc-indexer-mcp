# Copy to .env and replace every placeholder before running compose.
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3000
MCP_BEARER_TOKEN=replace-with-long-random-bearer-token

ADMIN_HTTP_HOST=0.0.0.0
ADMIN_HTTP_PORT=3100
ADMIN_COOKIE_SECURE=false
ADMIN_SESSION_TTL_SECONDS=604800
ADMIN_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
ADMIN_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
ADMIN_AUTH_LOG_LEVEL=INFO
ADMIN_STATIC_ASSETS_DIR=apps/admin-console/client/dist
# Optional first-run bootstrap. Leave unset after the first admin exists.
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com
# ADMIN_BOOTSTRAP_PASSWORD=replace-with-initial-admin-password

POSTGRES_DB=bun_dev_intel
POSTGRES_USER=bun_dev_intel
POSTGRES_PASSWORD=replace-with-database-password
DATABASE_URL=postgres://bun_dev_intel:replace-with-database-password@postgres-pgvector:5432/bun_dev_intel

EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: request a specific embedding size from OpenAI-compatible providers.
# The current remote docs pgvector schema requires 1536 dimensions.
# OPENAI_EMBEDDING_DIMENSIONS=1536
# Optional: point at an OpenAI-compatible local embedding server, for example Ollama or LM Studio.
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1

DOCS_REFRESH_INTERVAL=7d
DOCS_REFRESH_RUNNING_TIMEOUT_SECONDS=1800
DOCS_WORKER_POLL_SECONDS=300
DOCS_REFRESH_MAX_PAGES_PER_RUN=500
DOCS_REFRESH_MAX_EMBEDDINGS_PER_RUN=2000
DOCS_REFRESH_MAX_CONCURRENCY=4
DOCS_SEARCH_DEFAULT_LIMIT=5
DOCS_SEARCH_MAX_LIMIT=20
DOCS_ALLOWED_ORIGINS=https://agent.example.com
