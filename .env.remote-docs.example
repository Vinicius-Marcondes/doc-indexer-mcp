# Copy to .env.remote-docs and replace every placeholder before running compose.
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3000
MCP_BEARER_TOKEN=replace-with-long-random-bearer-token

POSTGRES_DB=bun_dev_intel
POSTGRES_USER=bun_dev_intel
POSTGRES_PASSWORD=replace-with-database-password
DATABASE_URL=postgres://bun_dev_intel:replace-with-database-password@postgres-pgvector:5432/bun_dev_intel

EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

DOCS_REFRESH_INTERVAL=7d
DOCS_REFRESH_MAX_PAGES_PER_RUN=500
DOCS_REFRESH_MAX_EMBEDDINGS_PER_RUN=2000
DOCS_REFRESH_MAX_CONCURRENCY=4
DOCS_SEARCH_DEFAULT_LIMIT=5
DOCS_SEARCH_MAX_LIMIT=20
DOCS_ALLOWED_ORIGINS=https://agent.example.com
