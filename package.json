{
  "name": "bun-dev-intel-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Source-backed MCP server for Bun project intelligence.",
  "workspaces": [
    "apps/admin-console/client",
    "apps/admin-console/server",
    "packages/admin-contracts"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit && bun run admin:contracts:typecheck && bun run admin:server:typecheck && bun run admin:client:typecheck",
    "check": "bun test && bun run typecheck",
    "dev": "bun --watch src/server.ts",
    "admin:contracts:typecheck": "tsc -p packages/admin-contracts/tsconfig.json --noEmit",
    "admin:server:typecheck": "tsc -p apps/admin-console/server/tsconfig.json --noEmit",
    "admin:client:typecheck": "tsc -p apps/admin-console/client/tsconfig.json --noEmit",
    "admin:client:build": "bun --cwd apps/admin-console/client build",
    "admin:server:dev": "bun --cwd apps/admin-console/server dev",
    "admin:client:dev": "bun --cwd apps/admin-console/client dev"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/hono": "2.0.0-alpha.2",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "hono": "^4.12.18",
    "openai": "^6.37.0",
    "postgres": "^3.4.9",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "typescript": "^5.9.3"
  }
}
